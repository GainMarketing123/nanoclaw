TELEGRAM_BOT_TOKEN=

# CEO Telegram user ID — gates /approve, /reject, /pause, /reset-mode commands.
# Fail-closed: if unset, ALL CEO-only commands are blocked (not all pass).
# Get yours: message @userinfobot on Telegram, it replies with your numeric ID.
TELEGRAM_CEO_USER_ID=

# Mission Control HTTP Basic auth credentials. Fail-closed: if either is unset,
# the mission-control HTTP dashboard refuses to start (returns exit code 2 with
# stderr message). Set both to enable the dashboard. The historical "auth
# disabled" mode was removed because combined with the 0.0.0.0 listener it
# exposed the full dashboard and the ~/.atlas state it surfaces to every host
# that could reach MC_PORT.
MISSION_CONTROL_USER=
MISSION_CONTROL_PASS=
