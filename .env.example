TELEGRAM_BOT_TOKEN=

# CEO Telegram user ID — gates /approve, /reject, /pause, /reset-mode commands.
# Fail-closed: if unset, ALL CEO-only commands are blocked (not all pass).
# Get yours: message @userinfobot on Telegram, it replies with your numeric ID.
TELEGRAM_CEO_USER_ID=

# Mission Control HTTP Basic auth credentials. Fail-closed: if either is unset,
# the mission-control HTTP dashboard refuses to start (returns exit code 2 with
# stderr message). Set both to enable the dashboard. The historical "auth
# disabled" mode was removed because combined with the 0.0.0.0 listener it
# exposed the full dashboard and the ~/.atlas state it surfaces to every host
# that could reach MC_PORT.
MISSION_CONTROL_USER=
MISSION_CONTROL_PASS=

# IMPORTANT: This file (nanoclaw/.env) is for nanoclaw-specific config only.
# The shared secret QUALITY_CHECK_TOKEN below lives in ~/.atlas/.env on the
# VPS instead — that's the file mounted read-only into containers at
# /home/node/.atlas/.env, so the container-side response-interceptor can read
# it. Don't put QUALITY_CHECK_TOKEN here.
#
# To mint and install the token on the VPS:
#   openssl rand -hex 32
#   echo "QUALITY_CHECK_TOKEN=<value>" >> ~/.atlas/.env
#   sudo systemctl restart atlas-host-executor.service
#   ./container/build.sh   # rebuild containers so they pick up the new token
#
# Fail-closed: host-executor.py refuses to start (exit 2) if QUALITY_CHECK_TOKEN
# is unset; container-side callHaiku() treats a missing token as
# checkerUnavailable=true (audit-honest, response still flows).
